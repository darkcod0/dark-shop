<!DOCTYPE html>
<html lang="fa">
<head>
  <meta charset="UTF-8">
  <!-- تنظیمات viewport برای موبایل و دسکتاپ -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dark Shop</title>
  <style>
    body {
      margin: 0;
      font-family: sans-serif;
    }

    header {
      background: #111;
      color: #fff;
      padding: 15px;
      text-align: center;
    }

    header h1 {
      margin: 0;
      font-size: 2rem;
    }

    /* واکنش‌گرایی */
    @media (max-width: 768px) {
      header h1 {
        font-size: 1.5rem;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>Dark Shop</h1>
  </header>
</body>
</html>
